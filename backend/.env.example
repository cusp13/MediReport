OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PORT=4000
FRONTEND_ORIGIN=http://localhost:1234

# Accounts + history + family (leave MONGODB_URI blank to run anonymous-only)
MONGODB_URI=
JWT_SECRET=change-me-to-a-long-random-string

# Optional: Qdrant Cloud URL for RAG / Health Recovery Monitor feature
# Leave blank to disable (app works fine without it)
QDRANT_URL=
