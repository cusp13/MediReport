OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PORT=4000
FRONTEND_ORIGIN=http://localhost:1234

# Accounts + history + family (leave MONGODB_URI blank to run anonymous-only)
MONGODB_URI=
JWT_SECRET=change-me-to-a-long-random-string

# Optional: Qdrant for RAG / Health Recovery Monitor feature
# Leave blank to disable (app works fine without it).
# QDRANT_API_KEY is required if QDRANT_URL points at Qdrant Cloud —
# without it every request gets rejected with 403 Forbidden.
QDRANT_URL=
QDRANT_API_KEY=
